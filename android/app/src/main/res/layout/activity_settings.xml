<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Access password -->
        <TextView style="@style/SectionHeader" android:text="Access password" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/accessPasswordInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="text" />

            <Button
                android:id="@+id/regenButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Regenerate" />
        </LinearLayout>

        <!-- Printing -->
        <TextView style="@style/SectionHeader" android:text="Printing" />

        <EditText
            android:id="@+id/widthInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Print width (px, default 384)"
            android:inputType="number" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Default print mode" android:layout_marginTop="8dp" />

        <Spinner
            android:id="@+id/defaultModeSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- HTTP -->
        <TextView style="@style/SectionHeader" android:text="HTTP server (LAN)" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/httpEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable HTTP server" />

        <EditText
            android:id="@+id/httpPortInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Port (default 8080)"
            android:inputType="number" />

        <!-- MQTT -->
        <TextView style="@style/SectionHeader" android:text="MQTT" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/mqttEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable MQTT" />

        <EditText android:id="@+id/mqttHostInput" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Broker host" android:inputType="text" />

        <EditText android:id="@+id/mqttPortInput" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Broker port (default 1883)" android:inputType="number" />

        <EditText android:id="@+id/mqttUserInput" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Username (optional)" android:inputType="text" />

        <EditText android:id="@+id/mqttPassInput" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Password (optional)" android:inputType="textPassword" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/mqttTls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Use TLS" />

        <EditText android:id="@+id/mqttPrefixInput" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Topic prefix (default sunmi/printhub/)" android:inputType="text" />

        <!-- Internet listener -->
        <TextView style="@style/SectionHeader" android:text="Internet listener" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/internetEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable internet listener" />

        <EditText android:id="@+id/internetDomainInput" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Server domain (e.g. pos.example.com)" android:inputType="textUri" />

        <TextView
            android:id="@+id/internetStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: unknown"
            android:layout_marginTop="4dp"
            android:textStyle="bold" />

        <!-- Confer chat server -->
        <TextView style="@style/SectionHeader" android:text="Confer chat server" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="The communally-agreed server that hosts Confer chat. Leave blank to use the internet-listener domain above. Sign in with your Confer account on the Confer tab."
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText android:id="@+id/conferServerInput" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Confer server (blank = same as above)" android:inputType="textUri" />

        <!-- Watchtower (HMAC device identity) -->
        <TextView style="@style/SectionHeader" android:text="Watchtower pairing" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Issue a device secret in the server's Watchtower dashboard (Devices tab), then paste it here. The internet connection is HMAC-signed with it, and this printer reports its own errors to Watchtower automatically."
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText android:id="@+id/deviceIdInput" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Device id (matches the dashboard)" android:inputType="text" />

        <EditText android:id="@+id/deviceSecretInput" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Device secret (sph_…), required for the internet link" android:inputType="textPassword" />

        <Button
            android:id="@+id/scanQrButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Scan pairing QR" />

        <!-- System -->
        <TextView style="@style/SectionHeader" android:text="System" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/autoStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start on boot" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/wallpaperSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Use home screen wallpaper as background" />

        <Button
            android:id="@+id/batteryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ignore battery optimizations" />

        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Save and restart services" />

    </LinearLayout>
</ScrollView>
